# --- Identificação ---
CONTAINER_NAME=devcp
HOSTNAME=devcp.perciocastelo.com.br
ROOT_PASSWORD=YOUR_ROOT_PASSWORD

# --- Redes e Acesso ---
SSH_PORT_HOST=22028
SSH_PORT_CONTAINER=22
CPANEL_SSL_PORT=2083
CPANEL_NON_SSL_PORT=2082
WHM_SSL_PORT=2087
WHM_NON_SSL_PORT=2086
HTTP_PORT_HOST=8091
HTTPS_PORT_HOST=8447
HTTP_PORT_CONTAINER=80
HTTPS_PORT_CONTAINER=443

# --- Recursos (Recomendado para cPanel) ---
CPU_LIMIT=2.0
MEM_LIMIT=4G
MEM_RESERVATION=2G

# --- Sistema ---
TIMEZONE=America/Sao_Paulo
LANG=C.utf8

# --- Opções de Instalação cPanel ---
# Flags opcionais: --skip-all-imunify --skip-wptoolkit --skip-systemd
