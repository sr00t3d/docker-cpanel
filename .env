# --- Identification ---
CONTAINER_NAME=cpanel-server
HOSTNAME=HOSTNAME.DOMAIN.COM
ROOT_PASSWORD=YOUR_ROOT_PASSWORD

# --- Networks and Access ---
SSH_PORT_HOST=22028         ## SSH CONNECTION PORT
SSH_PORT_CONTAINER=22028    ## SSH CONTAINER CONNECTION PORT
CPANEL_SSL_PORT=2083        ## CPANEL SSL PORT
CPANEL_NON_SSL_PORT=2082    ## CPANEL NON SSL PORT
WHM_SSL_PORT=2087           ## WHM SSL PORT
WHM_NON_SSL_PORT=2086       ## WHM NON SL PORT
HTTP_PORT_HOST=8080         ## HTTP PORT
HTTPS_PORT_HOST=8443        ## HTTP SSL PORT
HTTP_PORT_CONTAINER=80      ## HTTP CONTAINER PORT
HTTPS_PORT_CONTAINER=443    ## HTTP CONTAINER SSL PORT

# --- Features (Recommended cPanel) ---
# https://docs.cpanel.net/installation-guide/system-requirements/
# https://docs.cpanel.net/installation-guide/system-requirements-almalinux/
CPU_LIMIT=2.0
MEM_LIMIT=4G
MEM_RESERVATION=2G

# --- System ---
TIMEZONE=America/Sao_Paulo  # CHANGE TO YOUR TIMEZONE, LIST HERE https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
LANG=C.utf8
